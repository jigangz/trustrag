# Groq API Key (free — powers LLM generation and trust verification)
GROQ_API_KEY=gsk-your-key-here

# Database
DATABASE_URL=postgresql://trustrag:trustrag@db:5432/trustrag

# LLM model for generation (Groq)
LLM_MODEL=llama-3.3-70b-versatile

# Groq model for trust verification
GROQ_MODEL=llama-3.3-70b-versatile

# Chunking config
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval config
TOP_K=5

# Query cache (Postgres-backed, eliminates Groq calls for hot queries)
QUERY_CACHE_ENABLED=false
QUERY_CACHE_TTL_HOURS=24
